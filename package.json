{
  "name": "gaia-agent",
  "private": true,
  "version": "0.3.8",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.17.0 <25"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run prepare:runtime && tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "copy-cesium": "node scripts/copy-cesium.mjs",
    "update-bridge": "node scripts/update-bridge.mjs",
    "prepare:runtime": "node scripts/prepare-runtime-bundle.mjs",
    "postinstall": "npm run copy-cesium",
    "predev": "npm run update-bridge",
    "prebuild": "npm run update-bridge",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{js,ts,json}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{js,ts,json}\" \".github/workflows/*.yml\"",
    "test": "vitest run",
    "test:mcp-contract": "cargo test --manifest-path src-tauri/Cargo.toml --test mcp_contract",
    "sbom": "node scripts/generate-sbom.mjs",
    "test:watch": "vitest",
    "check:web": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --locked --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "check": "npm run check:web && npm run check:rust"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.10.1",
    "@zip.js/zip.js": "^2.8.26",
    "ai": "^7.0.9",
    "cesium": "1.142.0",
    "cesium-mcp-runtime": "1.142.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^26.0.3",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.1.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "use-stick-to-bottom": "^1.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cesium-mcp-bridge": "1.142.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
