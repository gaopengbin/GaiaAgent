# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: dashscope | openai | openai_compat | ollama | anthropic | deepseek
LLM_PROVIDER=openai_compat

# Model name (provider-specific default used if omitted)
# MODEL_NAME=qwen-max          # dashscope
# MODEL_NAME=gpt-4o-mini       # openai
# MODEL_NAME=qwen2.5:7b        # ollama
# MODEL_NAME=claude-3-5-sonnet-20241022  # anthropic
# MODEL_NAME=deepseek-chat     # deepseek
# MODEL_NAME=local-model       # openai_compat

# ── Provider-specific keys ───────────────────────────────────────────────────

# DashScope / Qwen (https://dashscope.console.aliyun.com/apiKey)
# DASHSCOPE_API_KEY=your_key_here

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your_key_here

# OpenAI-compatible API (LM Studio / vLLM / LocalAI / DeepSeek-local…)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=local

# Anthropic / Claude (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=your_key_here

# DeepSeek (https://platform.deepseek.com/api_keys)
# DEEPSEEK_API_KEY=your_key_here

# Ollama (local, no key needed — install: https://ollama.com)
# OLLAMA_HOST=http://localhost:11434

# cesium-mcp-runtime WebSocket port (default 9100)
CESIUM_WS_PORT=9100

# cesium-mcp tool locale: en (default) or zh-CN
CESIUM_LOCALE=zh-CN

# cesium-mcp enabled toolsets (comma-separated, or "all")
# default: view,entity,layer,interaction
CESIUM_TOOLSETS=all

